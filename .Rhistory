apply(dcon_scaled, 2, sd)
#prcomp usa SVD; center=TRUE, scale.=TRUE también estandariza internamente
pca <- prcomp(dcon, center = TRUE, scale. = TRUE)
#variancia explicada
var_exp <- pca$sdev^2
var_exp_ratio <- var_exp / sum(var_exp)
cum_exp_ratio <- cumsum(var_exp_ratio)
