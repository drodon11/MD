loadings <- pca$rotation[, 1:4]
loadings_df <- as.data.frame(loadings) %>% # Convertir matriz a DF
tibble::rownames_to_column(var = "Variable") %>% # Mover nombres de variables (taxAmount, etc.) a una columna
tidyr::pivot_longer(
cols = starts_with("PC"), # Coger columnas que empiecen por "PC"
names_to = "Componente",  # Nombre para la columna de PCs (PC1, PC2...)
values_to = "Carga"       # Nombre para la columna de valores numéricos
)
# Aseguramos que el orden de las variables en el gráfico coincida
# con el orden original en la matriz.
loadings_df$Variable <- factor(loadings_df$Variable, levels = rownames(loadings))
# 2. Generar el gráfico de barras facetado
plot_loadings <- ggplot(loadings_df, aes(x = Variable, y = Carga, fill = Carga)) +
geom_col() + # Crear las barras usando el valor exacto de la carga
# Usamos facetas: creamos un mini-gráfico para cada Componente
facet_wrap(~ Componente, ncol = 2, scales = "free_x") +
# Estilo visual
theme_minimal() +
# Escala de colores gradient2 para diferenciar positivo (azul) vs negativo (rojo)
scale_fill_gradient2(
low = "red4", mid = "white", high = "blue4",
midpoint = 0, guide = "none" # guide="none" oculta la leyenda de color redundante
) +
# Rotar etiquetas del eje X porque son largas y se solapan
theme(
axis.text.x = element_text(angle = 45, hjust = 1, size = 9),
panel.grid.minor = element_blank(),
strip.background = element_rect(fill = "gray90", color = "black"), # Estilo de cabeceras de facetas
strip.text = element_text(face = "bold")
) +
# Etiquetas
labs(
title = "Contribución de Variables Originales a los 4 Componentes Principales",
subtitle = "Visualización de la matriz de Cargas (Loadings)",
x = "Variables Numéricas Originales",
y = "Carga (Loading)"
)
# Mostrar el gráfico en RStudio
print(plot_loadings)
# 2. Generar el gráfico mejorado (Barras horizontales)
plot_loadings_intuitivo <- ggplot(loadings_df, aes(x = Variable, y = Carga, fill = Carga)) +
geom_col() +
# Añadimos una línea punteada en el 0 para distinguir visualmente positivo de negativo
geom_hline(yintercept = 0, linetype = "dashed", color = "gray30", linewidth = 0.6) +
# Ponemos los 4 gráficos en una cuadrícula de 2x2
facet_wrap(~ Componente, ncol = 2) +
# ¡LA MAGIA!: Giramos el gráfico para que las barras sean horizontales
coord_flip() +
# Colores: Rojo (negativo), Blanco (cero), Azul (positivo)
scale_fill_gradient2(
low = "#B2182B", mid = "white", high = "#2166AC",
midpoint = 0, guide = "none"
) +
# Tema limpio para aprovechar al máximo el espacio de la imagen
theme_bw() +
theme(
strip.background = element_rect(fill = "#f0f0f0", color = "NA"), # Cabeceras más discretas
strip.text = element_text(face = "bold", size = 11),
axis.text.y = element_text(face = "bold", size = 10), # Variables bien legibles
axis.text.x = element_text(size = 9),
panel.grid.major.y = element_blank(), # Quitamos rayas horizontales innecesarias
panel.border = element_rect(color = "gray80")
) +
# Etiquetas
labs(
title = "Contribución de Variables Originales (Loadings)",
subtitle = "Dirección y magnitud de las variables en los 4 Componentes Principales",
x = NULL, # Ocultamos el título "Variable" porque es obvio y ahorra espacio
y = "Valor de la Carga (Loading)"
)
print(plot_loadings_intuitivo)
# 2. Generar el gráfico mejorado (Barras horizontales)
