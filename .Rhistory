plot(res_hc, main = "Dendrograma de Vuelos (Métrica: Gower, Agregación: Ward)",
xlab = "Vuelos", sub = "", ylab = "Distancia (Inercia)", cex = 0.5)
# Instalación y carga de paquetes necesarios
list.of.packages <- c("cluster", "dplyr")
