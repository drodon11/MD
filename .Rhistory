#"desestandarizar" para volver a escala original
means <- attr(df_scaled, "scaled:center")
sds <- attr(dcon_scaled, "scaled:scale")
Xrec <- sweep(Xstd_hat, 2, sds, `*`)
Xrec <- sweep(Xrec, 2, means, `+`)
#"desestandarizar" para volver a escala original
