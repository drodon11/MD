geom_hline(yintercept = 0.8, linetype = "dashed", color = "black") +
labs(x = "Componente Principal", y = "Varianza acumulada",
title = "Varianza Acumulada (>80%)") +
theme_minimal() +
scale_x_continuous(breaks = seq_along(scree_df$CumExp))
